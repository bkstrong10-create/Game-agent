<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0A0A0A" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="2dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="AI Game Agent"
                android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvGames"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 games" android:textColor="#555555" android:textSize="11sp"
                android:fontFamily="monospace" android:gravity="end"/>
        </LinearLayout>

        <!-- Status row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="14dp">
            <TextView android:id="@+id/tvStatus"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="NOT CONNECTED" android:textColor="#FF9800" android:textSize="12sp"/>
            <TextView android:id="@+id/tvCost"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="$0.0000" android:textColor="#444444" android:textSize="11sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Accessibility button -->
        <Button android:id="@+id/btnAccessibility"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:text="Enable Accessibility Service"
            android:layout_marginBottom="12dp"/>

        <!-- API Key -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Anthropic API Key" android:textColor="#888888" android:textSize="10sp"/>
        <EditText android:id="@+id/etApiKey"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="sk-ant-..." android:inputType="textPassword"
            android:textColor="#FFFFFF" android:textColorHint="#333333"
            android:padding="10dp" android:background="#141414"
            android:layout_marginBottom="10dp"/>

        <!-- Budget limit -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Budget limit ($)" android:textColor="#888888" android:textSize="10sp"/>
                <EditText android:id="@+id/etBudget"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="1.00" android:inputType="numberDecimal"
                    android:textColor="#FFFFFF" android:padding="10dp"
                    android:background="#141414"/>
            </LinearLayout>
            <View android:layout_width="8dp" android:layout_height="1dp"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Delay (ms)" android:textColor="#888888" android:textSize="10sp"/>
                <EditText android:id="@+id/etDelay"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="2000" android:inputType="number"
                    android:textColor="#FFFFFF" android:padding="10dp"
                    android:background="#141414"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Speed presets -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Speed preset" android:textColor="#888888" android:textSize="10sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <Button android:id="@+id/btnFast"
                android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                android:text="Fast\n0.5s" android:textSize="10sp"/>
            <Button android:id="@+id/btnNormal"
                android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                android:text="Normal\n2s" android:textSize="10sp" android:layout_marginStart="4dp"/>
            <Button android:id="@+id/btnSlow"
                android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                android:text="Slow\n4s" android:textSize="10sp" android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Profiles -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <Button android:id="@+id/btnSaveProfile"
                android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                android:text="Save Profile" android:textSize="11sp"/>
            <Button android:id="@+id/btnLoadProfile"
                android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                android:text="Load Profile" android:textSize="11sp" android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Game Name + Generate -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Game Name" android:textColor="#888888" android:textSize="10sp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">
            <EditText android:id="@+id/etGameName"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:hint="e.g. Klondike Solitaire" android:inputType="text"
                android:textColor="#FFFFFF" android:textColorHint="#333333"
                android:padding="10dp" android:background="#141414"/>
            <Button android:id="@+id/btnGenerate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Generate" android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Game Context -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Game Context" android:textColor="#888888" android:textSize="10sp"/>
        <EditText android:id="@+id/etGameContext"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Type game name above and tap Generate"
            android:inputType="textMultiLine" android:minLines="4" android:gravity="top|start"
            android:textColor="#FFFFFF" android:textColorHint="#333333"
            android:padding="10dp" android:background="#141414"
            android:layout_marginBottom="16dp"/>

        <!-- Main button -->
        <Button android:id="@+id/btnStartStop"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="START AGENT" android:textSize="15sp" android:textStyle="bold"
            android:layout_marginBottom="14dp"/>

        <!-- Log -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Log" android:textColor="#888888" android:textSize="10sp"/>
        <TextView android:id="@+id/tvLog"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:minHeight="120dp" android:text="—"
            android:textColor="#555555" android:textSize="10sp"
            android:fontFamily="monospace" android:padding="10dp"
            android:background="#141414"/>

    </LinearLayout>
</ScrollView>
